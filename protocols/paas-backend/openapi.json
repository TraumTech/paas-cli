        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": {},
                "description": "Контракт-кандидат — OpenAPI-документ",
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
